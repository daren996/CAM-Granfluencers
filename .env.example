# Example environment variables for this repository.
# Keep this file synchronized with `.env`.

# TikHub API token used to authenticate requests.
TIKHUB_API_KEY=your_tikhub_api_key_here

# Base API domain. Use `https://api.tikhub.dev` if requests run from Mainland China.
TIKHUB_BASE_URL=https://api.tikhub.io

# Request timeout in seconds for each API call.
TIKHUB_TIMEOUT=30

# Maximum request rate for your client, usually interpreted as requests per minute.
TIKHUB_RATE_LIMIT=60

# Number of retry attempts after transient failures such as timeouts or 5xx responses.
TIKHUB_RETRY_COUNT=3
